[Unit]
Description=BTCUSDC Pivot Bot supervised live strategy
After=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/ethusdc-pivot-bot
Environment=I_APPROVE_FINAL_LIVE_STRATEGY_START=YES
ExecStart=%h/ethusdc-pivot-bot/scripts/run_final_live_strategy_btcusdc_1h.sh
Restart=on-failure
RestartSec=10
KillSignal=SIGTERM
TimeoutStopSec=30

[Install]
WantedBy=default.target
